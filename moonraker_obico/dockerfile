FROM python3.9-slim

# Instalar dependęncias necessárias
RUN apt-get update && apt-get install -y 
    git 
    build-essential 
    && rm -rf varlibaptlists

# Clonar o repositório oficial
WORKDIR app
RUN git clone httpsgithub.comTheSpaghettiDetectivemoonraker-obico.git .
 
# Instalar dependęncias Python
RUN pip install --no-cache-dir -r requirements.txt

# Copiar configuraçăo customizada
COPY moonraker-obico.cfg appmoonraker-obico.cfg

# Expor a porta usada pelo Moonraker-Obico
EXPOSE 7125

# Comando de inicializaçăo
CMD [python, moonraker-obico.py, -c, appmoonraker-obico.cfg]
